	keywords = {mitochondrial diseases, molecular diagnosis, mtDNA, mutation},
	pages = {1364},
	file = {Full Text:C\:\\Users\\JJ\\Zotero\\storage\\S7NRVLP3\\Habbane et al. - 2021 - Human Mitochondrial DNA Particularities and Diseases.pdf:application/pdf},
}

@article{dsouza_mitochondrial_2018,
