@article{hua_survival_2004,
	title = {Survival motor neuron protein facilitates assembly of stress granules},
	volume = {572},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
	issn = {0014-5793, 1873-3468},
	url = {https://febs.onlinelibrary.wiley.com/doi/10.1016/j.febslet.2004.07.010},
	doi = {10.1016/j.febslet.2004.07.010},
	abstract = {The survival motor neuron (SMN) protein forms cytoplasmic granules when overexpressed. We report here that SMN co‐localizes with TIA‐1/R and G3BP, protein assemblers of stress granules (SGs), and that SMN is co‐immunoprecipitated with TIA‐1/R, suggesting that SMN granules are SGs. Formation of SMN granules precedes accumulation of TIA‐1/R, indicating that SMN serves as a facilitator of SG formation. However, the exon 7 skipping product, SMNΔ7, is largely retained in the nucleus and forms nuclear granules, indicating that exon 7 is critical for SG formation. Our findings reveal a novel SMN function and possible SG involvement in the pathogenesis of spinal muscular atrophy.},
	language = {en},
	number = {1-3},
	urldate = {2026-04-01},
	journal = {FEBS Letters},
	author = {Hua, Yimin and Zhou, Jianhua},
	month = aug,
	year = {2004},
	pages = {69--74},
}

