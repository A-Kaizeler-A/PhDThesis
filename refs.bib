	file = {Full Text:C\:\\Users\\JJ\\Zotero\\storage\\98YNMF4B\\Abrahamyan et al. - 2010 - Novel Staufen1 ribonucleoproteins prevent formation of stress granules but favour encapsidation of H.pdf:application/pdf},
