@article{bird_highly_2018,
	title = {Highly efficient 5' capping of mitochondrial {RNA} with {NAD}+ and {NADH} by yeast and human mitochondrial {RNA} polymerase},
	volume = {7},
	issn = {2050-084X},
	doi = {10.7554/eLife.42179},
	abstract = {Bacterial and eukaryotic nuclear RNA polymerases (RNAPs) cap RNA with the oxidized and reduced forms of the metabolic effector nicotinamide adenine dinucleotide, NAD+ and NADH, using NAD+ and NADH as non-canonical initiating nucleotides for transcription initiation. Here, we show that mitochondrial RNAPs (mtRNAPs) cap RNA with NAD+ and NADH, and do so more efficiently than nuclear RNAPs. Direct quantitation of NAD+- and NADH-capped RNA demonstrates remarkably high levels of capping in vivo: up to {\textasciitilde}60\% NAD+ and NADH capping of yeast mitochondrial transcripts, and up to {\textasciitilde}15\% NAD+ capping of human mitochondrial transcripts. The capping efficiency is determined by promoter sequence at, and upstream of, the transcription start site and, in yeast and human cells, by intracellular NAD+ and NADH levels. Our findings indicate mtRNAPs serve as both sensors and actuators in coupling cellular metabolism to mitochondrial transcriptional outputs, sensing NAD+ and NADH levels and adjusting transcriptional outputs accordingly.},
	language = {eng},
	journal = {eLife},
	author = {Bird, Jeremy G. and Basu, Urmimala and Kuster, David and Ramachandran, Aparna and Grudzien-Nogalska, Ewa and Towheed, Atif and Wallace, Douglas C. and Kiledjian, Megerditch and Temiakov, Dmitry and Patel, Smita S. and Ebright, Richard H. and Nickels, Bryce E.},
