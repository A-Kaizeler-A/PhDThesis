	keywords = {Humans, RNA, Messenger, HeLa Cells, Cytoplasmic Granules, HEK293 Cells, Gene Expression Regulation, stress granules, Protein Biosynthesis, Cell Fractionation, Cytoplasm, decay, gene expression regulation, Gene Ontology, Molecular Sequence Annotation, P-bodies, phase separation, phase transition, Phase Transition, Proteome, regulon, Regulon, Ribonucleoproteins, RNA Stability, RNP condensation, RNP granules, translation repression},
	pages = {144--157.e5},
	file = {Full Text:C\:\\Users\\JJ\\Zotero\\storage\\ATVF7MDY\\Hubstenberger et al. - 2017 - P-Body Purification Reveals the Condensation of Repressed mRNA Regulons.pdf:application/pdf},
