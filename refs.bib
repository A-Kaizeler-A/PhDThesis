	keywords = {Animals, Humans, gene expression, Cell Differentiation, CMTR1, differentiation, embryonic stem cells, Histones, Methyltransferases, RNA cap, RNA Caps, RNMT, Transcription, Genetic},
	pages = {1131--1141},
	file = {Full Text:C\:\\Users\\JJ\\Zotero\\storage\\SWM9EQ8I\\Liang et al. - 2023 - The RNA cap methyltransferases RNMT and CMTR1 co-ordinate gene expression during neural differentiat.pdf:application/pdf},
}

