	keywords = {Animals, Humans, Mice, Gene Expression Profiling, Tumor Cells, Cultured, Antineoplastic Agents, Cell Differentiation, Apoptosis, Biomarkers, Tumor, Cell Proliferation, Colorectal Neoplasms, Dose-Response Relationship, Drug, Drug Screening Assays, Antitumor, Fluorouracil, Gene Expression Regulation, Neoplastic, Mice, Nude, Models, Biological, Neoplasms, Experimental, Oxaliplatin, Structure-Activity Relationship},
	pages = {616--633},
