	journal = {Journal of Cell Science},
	author = {Abrahamyan, Levon G. and Chatel-Chaix, Laurent and Ajamian, Lara and Milev, Miroslav P. and Monette, Anne and Clément, Jean-François and Song, Rujun and Lehmann, Martin and DesGroseillers, Luc and Laughrea, Michael and Boccaccio, Graciela and Mouland, Andrew J.},
